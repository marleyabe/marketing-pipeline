# ============================================================
# Production environment — NÃO COMMITAR
# Copia para .env no servidor e preenche
# ============================================================

# Postgres (gerar: openssl rand -base64 32)
POSTGRES_PASSWORD=

# Airflow admin
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=
AIRFLOW_ADMIN_EMAIL=

# Airflow Fernet (gerar: python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())')
AIRFLOW_FERNET_KEY=

# Meta Ads
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=

# Google Ads
GOOGLE_DEVELOPER_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_LOGIN_CUSTOMER_ID=

# API (gerar: openssl rand -base64 48)
API_KEY_PEPPER=

# Alerting
DISCORD_WEBHOOK_URL=

# NOTA: domínios (AIRFLOW_DOMAIN, API_DOMAIN) e Let's Encrypt email são
# configurados no Caddyfile compartilhado em /opt/infra/caddy/Caddyfile.
# Este projeto só precisa estar na rede externa `caddy-net`.
